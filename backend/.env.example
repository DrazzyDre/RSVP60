# ------------------------------------------------------------------
# RSVP60 backend environment
# Copy this file to `.env` and adjust as needed.
# ------------------------------------------------------------------

# Runtime environment: development | production
# - development: tables auto-create on startup; demo seed is allowed.
# - production:  NO auto-create (use Alembic migrations); demo seed is blocked;
#                an insecure JWT_SECRET refuses to boot.
APP_ENV=development

# Database.
# Default (zero-config local dev): a local SQLite file.
DATABASE_URL=sqlite:///./rsvp60.db
# Docker Compose uses Postgres:
#   DATABASE_URL=postgresql+psycopg2://rsvp60:rsvp60@db:5432/rsvp60
# Supabase / Postgres example:
#   DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# JWT auth secret. REQUIRED in production — the app refuses to start in
# production while this is the shipped default. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=dev-super-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Public site URL used to build shareable invite links (frontend origin).
SITE_URL=http://localhost:3005

# Comma-separated list of the exact frontend origins allowed to call the API
# (CORS). No wildcards, no trailing slash — e.g. in production set this to your
# deployed frontend origin(s): https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3005,http://127.0.0.1:3005,http://localhost:3000

# ------------------------------------------------------------------
# Email / guest communications (Phase 5)
# ------------------------------------------------------------------
# "console" -> emails are LOGGED, never sent. No credentials, no network — the
#              safe default for local dev, automated tests and CI.
# "resend"  -> transactional email via Resend (https://resend.com).
# In production the app refuses to boot if a live provider is selected but its
# credentials are missing.
EMAIL_BACKEND=console
# The from-identity for all outgoing mail. Required for a live provider.
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=RSVP60
# Resend API key — a SERVER-ONLY secret. Never put it in the frontend or any
# NEXT_PUBLIC_* variable, and it is never returned by the API or stored in the
# communication log. Only used when EMAIL_BACKEND=resend.
RESEND_API_KEY=
# Hard cap (seconds) on a single synchronous provider send.
EMAIL_TIMEOUT_SECONDS=10

# Simple in-memory rate limit for public RSVP submissions (per client IP).
RSVP_RATE_LIMIT_MAX=8
RSVP_RATE_LIMIT_WINDOW_SECONDS=60

# Throttle repeated FAILED admin logins (per client IP + email). Successful
# logins and normal authenticated API usage are never throttled. In-process
# only — use a shared store (Redis) for multi-instance production.
LOGIN_RATE_LIMIT_MAX_FAILURES=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# ------------------------------------------------------------------
# Flyer / image storage
# ------------------------------------------------------------------
# "local"    -> files saved under UPLOAD_DIR, served by the API from /media/...
# "supabase" -> files pushed to a Supabase Storage bucket (set SUPABASE_* below)
STORAGE_BACKEND=local
UPLOAD_DIR=uploads
# Max flyer upload size in bytes (default 5 MB).
MAX_UPLOAD_BYTES=5242880
# Absolute prefix for media URLs. Leave empty for app-relative "/media/..." paths
# (the frontend resolves them against NEXT_PUBLIC_API_URL).
MEDIA_BASE_URL=

# Supabase Storage (only used when STORAGE_BACKEND=supabase). When this backend
# is selected the app refuses to boot unless SUPABASE_URL and
# SUPABASE_SERVICE_ROLE_KEY are set.
#   - SUPABASE_SERVICE_ROLE_KEY is a SERVER-ONLY secret. Keep it on the backend
#     host only; NEVER put it in the frontend or any NEXT_PUBLIC_* variable.
#   - Create the bucket as a PUBLIC bucket named to match SUPABASE_STORAGE_BUCKET
#     so guests can load flyer images from the resolved public URL.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=flyers

# NOTE: the API port is a uvicorn flag, not an env var:
#   uvicorn app.main:app --reload --port 8010
