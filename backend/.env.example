# ------------------------------------------------------------------
# RSVP60 backend environment
# Copy this file to `.env` and adjust as needed.
# ------------------------------------------------------------------

# Database.
# Default (zero-config local dev): a local SQLite file.
DATABASE_URL=sqlite:///./rsvp60.db
# Supabase / Postgres example (uncomment and fill in):
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# JWT auth secret. CHANGE THIS in production (e.g. `openssl rand -hex 32`).
JWT_SECRET=dev-super-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=720

# The public site URL used to build shareable invite links (frontend origin).
SITE_URL=http://localhost:3000

# Comma-separated list of origins allowed to call the API (CORS).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
