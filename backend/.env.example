# ------------------------------------------------------------------
# RSVP60 backend environment
# Copy this file to `.env` and adjust as needed.
# ------------------------------------------------------------------

# Runtime environment: development | production
# - development: tables auto-create on startup; demo seed is allowed.
# - production:  NO auto-create (use Alembic migrations); demo seed is blocked;
#                an insecure JWT_SECRET refuses to boot.
APP_ENV=development

# Database.
# Default (zero-config local dev): a local SQLite file.
DATABASE_URL=sqlite:///./rsvp60.db
# Docker Compose uses Postgres:
#   DATABASE_URL=postgresql+psycopg2://rsvp60:rsvp60@db:5432/rsvp60
# Supabase / Postgres example:
#   DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# JWT auth secret. REQUIRED in production — the app refuses to start in
# production while this is the shipped default. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=dev-super-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Public site URL used to build shareable invite links (frontend origin).
SITE_URL=http://localhost:3005

# Comma-separated list of origins allowed to call the API (CORS). No wildcards.
CORS_ORIGINS=http://localhost:3005,http://127.0.0.1:3005,http://localhost:3000

# Simple in-memory rate limit for public RSVP submissions (per client IP).
RSVP_RATE_LIMIT_MAX=8
RSVP_RATE_LIMIT_WINDOW_SECONDS=60

# NOTE: the API port is a uvicorn flag, not an env var:
#   uvicorn app.main:app --reload --port 8010
