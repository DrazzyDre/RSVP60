# ------------------------------------------------------------------
# GatherArc backend — PRODUCTION environment template
# ------------------------------------------------------------------
# Copy the values into your host's dashboard (Render/Railway) as secrets — do
# NOT commit real values. The app FAILS FAST on boot if any of the production
# guards below are violated (see app/config.py::validate_runtime).

# Must be exactly "production": disables dev auto-create/seed and enables the
# production config guards.
APP_ENV=production

# Supabase Postgres connection string (Session/Transaction pooler URL is fine).
#   postgresql+psycopg2://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
DATABASE_URL=

# Strong, unique secret — REQUIRED. The app refuses to boot on the dev default.
#   openssl rand -hex 32
JWT_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Public frontend origin (your Vercel URL). Builds invite/QR/email links.
# REQUIRED and must NOT be localhost in production.
SITE_URL=https://your-app.vercel.app

# Exact frontend origin(s) allowed to call the API (comma-separated, no
# wildcard). REQUIRED; must include at least one non-localhost origin.
CORS_ORIGINS=https://your-app.vercel.app

# Enable ONLY behind a trusted reverse proxy (Render/Railway/Fly/LB) that sets
# X-Forwarded-For. Lets rate limiting see the real client IP.
TRUST_PROXY_HEADERS=true

# --- File storage: Supabase Storage --------------------------------
STORAGE_BACKEND=supabase
SUPABASE_URL=https://PROJECT.supabase.co
# SERVER-ONLY secret — never expose to the frontend / NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=
# The bucket must ALREADY EXIST as a PUBLIC bucket whose name matches this value
# EXACTLY (a mismatch shows as a `bucket_not_found` flyer-upload failure).
# Changing storage env vars requires a backend redeploy to take effect. Verify
# before going live: `python -m scripts.validate_storage [--write-test]`.
SUPABASE_STORAGE_BUCKET=gatherarc-flyers

# --- Email: Resend -------------------------------------------------
EMAIL_BACKEND=resend
# A verified Resend sender address/domain.
EMAIL_FROM_ADDRESS=invites@your-domain.com
EMAIL_FROM_NAME=GatherArc
# SERVER-ONLY secret — never expose to the frontend.
RESEND_API_KEY=
EMAIL_TIMEOUT_SECONDS=10

# --- Rate limiting (optional — sensible defaults shown) ------------
# In-process only (per instance). See DEPLOYMENT.md §5 for the multi-instance
# caveat. NOTE the exact variable names (they map to app/config.py fields):
#   login limiter:
LOGIN_RATE_LIMIT_MAX_FAILURES=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
#   public RSVP limiter:
RSVP_RATE_LIMIT_MAX=8
RSVP_RATE_LIMIT_WINDOW_SECONDS=60
