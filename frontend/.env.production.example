# Frontend production environment (Vercel).
#
# Set this in the Vercel project → Settings → Environment Variables (Production).
# It is a PUBLIC value baked into the client bundle — never put secrets in any
# NEXT_PUBLIC_* variable.

# The deployed backend API origin (your Render/Railway URL, https, no trailing
# slash). The frontend calls this for all API + media requests.
NEXT_PUBLIC_API_URL=https://your-api.onrender.com
