# Base URL of the GatherArc FastAPI backend.
# The documented dev flow (and Docker Compose) runs the backend on port 8010.
# In production, set this to your deployed backend origin (e.g.
# https://api.your-app.com) and add that same frontend origin to the backend's
# CORS_ORIGINS.
NEXT_PUBLIC_API_URL=http://localhost:8010

# NOTE: everything prefixed NEXT_PUBLIC_* is embedded in the browser bundle and
# is PUBLIC. Never put secrets here — the Supabase service role key and any
# storage credentials live only in the backend environment.

# --- Optional client error tracking (Phase 7) ---
# Leave blank to disable. When set to your Sentry PUBLIC DSN, uncaught client
# errors are reported (route + error only; guest PII is never sent). This is a
# public browser value — never the backend SENTRY_DSN.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
